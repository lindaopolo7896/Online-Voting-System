# Copy to .env and fill in. .env is git-ignored; this file is the template.

# --- Core Django ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
# Comma-separated, e.g. example.com,www.example.com (leave blank in dev)
ALLOWED_HOSTS=

# --- JWT ---
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# --- Email (OTP login codes) ---
# Dev default is the console backend (prints emails to the server stdout),
# so you can leave EMAIL_BACKEND blank locally. For real delivery, switch to
# the SMTP backend and fill in the host settings below.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-address@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=no-reply@voting.local

# --- OTP behaviour ---
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
